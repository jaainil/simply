{{!--
    SEO: BreadcrumbList JSON-LD Partial
    Ghost already outputs Article JSON-LD via ghost_head.
    This partial adds BreadcrumbList for rich breadcrumb results in SERPs.
    Usage: {{> "seo-jsonld"}}
--}}

{{#post}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": "{{url absolute='true'}}#breadcrumb",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "{{@site.title}}",
            "item": "{{@site.url}}"
        }{{#if primary_tag}},
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{primary_tag.name}}",
            "item": "{{primary_tag.url}}"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{title}}",
            "item": "{{url absolute='true'}}"
        }
        {{else}},
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{title}}",
            "item": "{{url absolute='true'}}"
        }
        {{/if}}
    ]
}
</script>
{{/post}}
